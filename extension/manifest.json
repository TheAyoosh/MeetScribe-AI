{
  "manifest_version": 3,
  "name": "MeetScribe AI",
  "version": "1.0.0",
  "description": "Real-time meeting transcription, speaker diarization & tone analysis powered by open-source AI",
  "permissions": [
    "activeTab",
    "storage",
    "tabCapture",
    "offscreen",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://app.zoom.us/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://zoom.us/*",
        "https://teams.microsoft.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/sidebar.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/audio-interceptor.js",
        "content/alert-engine.js",
        "content/sidebar.css",
        "assets/*",
        "popup/*"
      ],
      "matches": [
        "https://meet.google.com/*",
        "https://zoom.us/*",
        "https://teams.microsoft.com/*",
        "https://app.zoom.us/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
